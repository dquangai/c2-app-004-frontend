# Backend API (Vite proxy /api → target below).
# Start backend:
#   cd main-project/backend && py -m uvicorn main:app --host 127.0.0.1 --port 8013 --reload
# Start frontend (http://127.0.0.1:5174):
#   cd main-project/frontend && npm run dev
# If port 8013 is busy, stop old uvicorn/Python then restart both services.
VITE_API_PROXY_TARGET=http://127.0.0.1:8013
