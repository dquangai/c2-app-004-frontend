# API backend (optional — dev uses Vite proxy /api → backend)
# VITE_API_BASE_URL=http://127.0.0.1:8000
# Dev proxy target when using vite (see .env.development)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8001
# Provider member id for "Booked me" tab in Messages
# VITE_PROVIDER_MEMBER_ID=mem_001
VITE_DEFAULT_USER_ID=user_demo

# Admin dashboard (optional — can also enter key in UI)
# VITE_ADMIN_API_KEY=your-admin-api-key
